{
  "name": "sf-log-analyzer",
  "displayName": "SF Log Analyzer",
  "description": "Parse and visualise Salesforce debug logs — execution timeline, governor limits, code scan, and report in a VS Code webview.",
  "version": "1.0.0",
  "publisher": "nwmorph",
  "author": {
    "name": "Niklas Waller",
    "url": "https://github.com/nwmorph"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nwmorph/sf-log-analyzer.git"
  },
  "keywords": [
    "salesforce",
    "apex",
    "debug log",
    "log analyzer",
    "governor limits",
    "sfdx",
    "salesforce cli"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Debuggers",
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "contributes": {
    "commands": [
      {
        "command": "sf-log-analyzer.openLogVisualizer",
        "title": "SF Log Analyzer: Open Visualizer"
      },
      {
        "command": "sf-log-analyzer.loadDebugLog",
        "title": "SF Log Analyzer: Load in Analyzer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "sf-log-analyzer.loadDebugLog",
          "when": "resourceExtname == .log",
          "group": "1_modification"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "sf-log-analyzer.debugLog",
        "displayName": "SF Log Analyzer",
        "selector": [
          {
            "filenamePattern": "*.log"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0"
  }
}
